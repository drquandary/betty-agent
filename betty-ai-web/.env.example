# Claude API key — get one at https://console.anthropic.com/
# (Or if you're using a Claude subscription, the SDK may authenticate via the CLI)
ANTHROPIC_API_KEY=

# Optional OpenAI-compatible providers
OPENAI_API_KEY=
LOCAL_LLM_API_KEY=
# PARCC LiteLLM gateway (https://litellm.parcc.upenn.edu/v1) — request key from PARCC
LITELLM_API_KEY=

# Path to the wiki + betty-ai toolkit (relative to betty-ai-web/ or absolute)
# Default assumes betty-ai-web/ is a subdir of parcc1/
WIKI_PATH=../wiki
BETTY_AI_PATH=../betty-ai

# Phase 2+ will use these for SSH bridge to Betty
# BETTY_SSH_USER=jvadala
# BETTY_SSH_HOST=login.betty.parcc.upenn.edu
# BETTY_TERMINAL_WS_HOST=127.0.0.1
# BETTY_TERMINAL_WS_PORT=3001
# NEXT_PUBLIC_BETTY_TERMINAL_WS_PORT=3001
# Override the ssh binary used by the terminal bridge (default: resolved from PATH)
# BETTY_SSH_COMMAND=/usr/bin/ssh
