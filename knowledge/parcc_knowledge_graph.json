  "commands": [
    {
      "name": "identity checks",
      "examples": ["whoami", "hostname", "pwd", "date"],
      "purpose": "confirm current user, host, path, and timezone"
    },
    {
      "name": "quota check",
      "examples": ["parcc_quota.py"],
      "purpose": "inspect quota usage across storage pools"
    },
    {
      "name": "directory usage",
      "examples": ["parcc_du.py /vast/projects/<your-project>"],
      "purpose": "find large directories consuming project storage"
    },
    {
      "name": "module discovery",
      "examples": ["module avail", "module spider anaconda3", "module show anaconda3", "module load anaconda3"],
      "purpose": "discover and load installed software"
    },
    {
      "name": "conda basics",
      "examples": ["conda env list", "conda create -n tutorial"],
      "purpose": "manage personal Python environments"
    },
    {
      "name": "slurm overview",
      "examples": ["sinfo", "squeue -u $USER", "squeue | wc -l", "parcc_sfree.py"],
      "purpose": "inspect partitions, jobs, and available resources"
    },
    {
      "name": "gpu smoke test",
      "examples": ["srun -p dgx-b200 --gpus=1 -t 00:01:00 nvidia-smi"],
      "purpose": "verify basic GPU scheduling and visibility"
    },
    {
      "name": "qos inspection",
      "examples": ["parcc_sqos.py"],
      "purpose": "check allowed QOS settings and limits"
    },
    {
      "name": "usage report",
      "examples": ["parcc_sreport.py --user YOUR_PennKey"],
      "purpose": "review recent job usage"
    },
    {
      "name": "job debug",
      "examples": ["parcc_sdebug.py --job JOBID", "parcc_sdebug.py --node NODENAME"],
      "purpose": "inspect failures, node health, or preemption"
    },
    {
      "name": "mpi compile and run",
      "examples": [
        "mpicc -O2 -o hello_mpi_dgx hello_mpi.c",
        "srun --mpi=pmix ./hello_mpi_dgx",
        "sbatch mpi_genoa.sbatch",
        "sbatch mpi_dgx.sbatch",
        "tail -f slurm-<JobID>.out"
      ],
      "purpose": "build, submit, and inspect MPI tutorial jobs"
    },
    {
      "name": "data transfer",
      "examples": [
        "scp <your-local-file> <PennKey>@login.betty.parcc.upenn.edu:/vast/projects/<your-project>"
      ],
      "purpose": "copy local files into PARCC project storage"
    }
  ],
